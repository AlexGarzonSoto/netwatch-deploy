# ── JWT (genera con: openssl rand -hex 64) ────────────────────────────────
JWT_SECRET=REEMPLAZA_CON_CADENA_ALEATORIA_DE_64_CHARS_usa_openssl_rand_hex_64
JWT_REFRESH_SECRET=REEMPLAZA_CON_OTRA_CADENA_64_CHARS_usa_openssl_rand_hex_64_diferente

# ── PostgreSQL — puedes usar cualquier contraseña ──────────────────────────
POSTGRES_DB=netwatch
POSTGRES_USER=netwatch
POSTGRES_PASSWORD=NetWatch2024!

# ── RabbitMQ ──────────────────────────────────────────────────────────────
RABBITMQ_USER=netwatch
RABBITMQ_PASSWORD=NetWatch2024!

# ── Valkey ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=NetWatch2024!

# ── SMTP — déjalo en false, no es obligatorio para que funcione ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_MIN_SEVERITY=HIGH
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=

# ── Captura — verifica tu interfaz de red ────────────────────────────────
CAPTURE_INTERFACE=eth0
CAPTURE_ENABLED=true

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=NetWatch2024!

# ── Docker Hub — tu usuario real de hub.docker.com ───────────────────────
# Cámbialo por tu usuario exacto de hub.docker.com antes de ejecutar make iniciar
DOCKERHUB_USERNAME=
